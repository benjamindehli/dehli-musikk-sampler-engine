{
  "schema": 1,
  "format": "dmse-manifest",
  "library": "Kitchen Sink",
  "gainDb": -6.5,
  "polySaveDefault": false,
  "modes": [
    {
      "name": "Everything",
      "amp": { "attack": 0.01, "decay": 0.5, "sustain": 0.8, "release": 1.25, "volume": 0.9,
               "velTrack": 0.4, "enabled": true,
               "attackCurve": -100.0, "decayCurve": 100.0, "releaseCurve": 50.0 },
      "tags": [ { "name": "mono-choir", "polyphony": 1 } ],
      "groups": [
        {
          "uid": "grp_a",
          "tags": [ "layer-a", "mono-choir" ],
          "trigger": "attack",
          "loopCrossfadeMode": "equal_power",
          "velocity": { "lo": 0, "hi": 100 },
          "roundRobin": { "mode": "round_robin", "length": 2 },
          "silencing": { "mode": "fast", "byTags": [ "mono-choir" ] },
          "attack": 0.02, "decay": 0.3, "sustain": 0.7, "release": 0.9,
          "volume": 0.85, "velTrack": 0.5,
          "ampEnvEnabled": true,
          "pitchKeyTrack": false,
          "effects": [
            { "id": "gfx_gain", "type": "gain", "enabled": true, "gain": -3.0 },
            { "id": "gfx_lp",   "type": "lowpass", "enabled": false, "frequency": 4000.0, "resonance": 0.9 }
          ],
          "samples": [
            {
              "source": "flac:sink_a1", "loNote": 36, "hiNote": 48, "rootNote": 40,
              "lengthFrames": 96000, "sampleRate": 48000.0,
              "pitchKeyTrack": true, "pitchDrift": 0.25,
              "start": 100, "end": 95000, "volume": 0.75, "seqPosition": 1,
              "ampEnvEnabled": false, "onLoCC64": 0, "onHiCC64": 63,
              "loop": { "enabled": true, "start": 1000, "end": 90000, "crossfade": 512 }
            },
            {
              "source": "flac:sink_a2", "loNote": 49, "hiNote": 60, "rootNote": 52,
              "pitchKeyTrack": false,
              "loop": { "enabled": false, "start": 2000, "end": 80000, "crossfade": 256 }
            }
          ]
        },
        {
          "uid": "grp_b",
          "tags": [ "layer-b" ],
          "trigger": "release",
          "samples": [
            { "source": "flac:sink_b1", "loNote": 36, "hiNote": 60, "rootNote": 48, "pitchKeyTrack": true }
          ]
        }
      ],
      "effects": [
        { "id": "fx_lp",     "type": "lowpass",     "enabled": true,  "frequency": 12000.0, "resonance": 0.707 },
        { "id": "fx_hp",     "type": "highpass",    "enabled": false, "frequency": 40.0, "resonance": 1.2 },
        { "id": "fx_conv",   "type": "convolution", "enabled": true,  "mix": 0.25, "wet": 0.25,
          "outputLevel": 6.0, "ir": "ir:sink_room", "normalizeIr": false },
        { "id": "fx_gain",   "type": "gain",        "enabled": true,  "gain": -1.5 },
        { "id": "fx_shape",  "type": "wave_shaper", "enabled": true,  "drive": 4.0, "outputLevel": 0.41 },
        { "id": "fx_chorus", "type": "chorus",      "enabled": false, "mix": 0.5, "rate": 1.1, "depth": 0.3, "feedback": 0.1 },
        { "id": "fx_phaser", "type": "phaser",      "enabled": false, "mix": 1.0, "rate": 0.4, "depth": 0.6, "feedback": -0.2 }
      ],
      "sequences": [
        {
          "name": "strum-up", "length": 8, "rate": 12.0,
          "notes": [
            { "position": 0, "note": 60, "velocity": 1.0, "length": 2.0, "enabled": true,  "swallowNotes": true },
            { "position": 2, "note": 64, "velocity": 0.8, "length": 2.0, "enabled": false, "swallowNotes": false }
          ]
        }
      ],
      "modulators": [
        {
          "id": "mod_0", "shape": "sine", "frequency": 5.5, "modAmount": 0.15,
          "bindings": [
            { "type": "amp", "level": "instrument", "parameter": "GLOBAL_TUNING",
              "translationOutputMin": 0.0, "translationOutputMax": 0.5 },
            { "type": "amp", "level": "group", "targetId": "grp_a", "parameter": "AMP_VOLUME",
              "groupIndex": 0, "modBehavior": "add" }
          ]
        }
      ],
      "sequenceTriggers": [
        { "note": 24, "sequence": 0, "transpose": 12, "rate": 10.0,
          "loop": true, "trackVelocity": false, "swallow": true }
      ],
      "strumKeys": [
        { "note": 25, "seqOffset": 0 },
        { "note": 27, "seqOffset": 1, "rate": 8.0 }
      ],
      "ccBindings": [
        { "cc": 1, "parameter": "FREQUENCY", "targetId": "ctl_lfo", "groupIndex": 0,
          "controlIndex": 2, "normMin": 0.0, "normMax": 1.0 }
      ],
      "menuKeySwitches": [ { "note": 25, "option": 1 } ],
      "ui": {
        "background": "img:sink_bg",
        "width": 812, "height": 375, "cropTop": 40,
        "layoutMode": "relative", "bgMode": "top_left",
        "whiteKeyTint": "80FFE082", "blackKeyTint": "40FFE082",
        "tabs": [
          {
            "name": "main",
            "controls": [
              {
                "id": "ctl_vol", "rect": { "x": 10, "y": 20, "width": 48, "height": 48 },
                "label": "Volume", "valueType": "float", "min": 0.0, "max": 2.0, "value": 1.0,
                "textColor": "FFFDFEFF", "style": "custom_skin_vertical_drag",
                "skin": { "image": "img:sink_knob", "numFrames": 31, "orientation": "vertical" },
                "mouseDragSensitivity": 120.0, "controlIndex": 0, "visible": true,
                "bindings": [
                  { "type": "amp", "level": "instrument", "parameter": "AMP_VOLUME", "factor": 1.0 },
                  { "type": "amp", "level": "tag", "identifier": "layer-a", "parameter": "TAG_VOLUME",
                    "translation": "linear", "translationOutputMin": 0.0, "translationOutputMax": 3.0 }
                ]
              },
              {
                "id": "ctl_drive", "rect": { "x": 70, "y": 20, "width": 48, "height": 48 },
                "label": "Drive", "min": 0.0, "max": 10.0, "value": 2.0,
                "controlIndex": 1, "visible": false,
                "bindings": [
                  { "type": "effect", "level": "instrument", "targetId": "fx_shape",
                    "parameter": "FX_DRIVE", "effectIndex": 4, "position": 4,
                    "translationTable": "0,1;5,4;10,15", "translationReversed": true },
                  { "type": "control", "level": "ui", "parameter": "OPACITY", "targetId": "img_led",
                    "controlIndex": 1, "noteIndex": 0, "bindingIndex": 0, "seqIndex": 0,
                    "modAmount": 0.5, "translationValue": 0.5 }
                ]
              },
              {
                "id": "ctl_lfo", "rect": { "x": 130, "y": 20, "width": 48, "height": 48 },
                "label": "Vibrato", "min": 0.0, "max": 8.0, "value": 0.0,
                "controlIndex": 2,
                "bindings": [
                  { "type": "modulator", "level": "instrument", "targetId": "mod_0",
                    "parameter": "FREQUENCY", "translation": "linear",
                    "translationOutputMin": 0.0, "translationOutputMax": 8.0, "position": 0 }
                ]
              }
            ],
            "buttons": [
              {
                "id": "btn_stereo", "rect": { "x": 190, "y": 20, "width": 40, "height": 20 },
                "style": "image", "value": 0, "controlIndex": 3, "visible": true,
                "states": [
                  { "name": "off", "mainImage": "img:sink_btn_off", "hoverImage": "img:sink_btn_off_h",
                    "clickImage": "img:sink_btn_off_c",
                    "bindings": [
                      { "type": "amp", "level": "group", "targetId": "grp_a",
                        "parameter": "PAN", "translation": "fixed_value", "translationValue": "0" }
                    ] },
                  { "name": "on", "mainImage": "img:sink_btn_on",
                    "bindings": [
                      { "type": "amp", "level": "group", "targetId": "grp_a",
                        "parameter": "PAN", "translation": "fixed_value", "translationValue": "-100" },
                      { "type": "effect", "level": "instrument", "targetId": "fx_conv",
                        "parameter": "FX_IR_FILE", "translationValue": "ir:sink_hall" }
                    ] }
                ]
              },
              {
                "id": "btn_dt", "rect": { "x": 240, "y": 20, "width": 40, "height": 20 },
                "style": "image", "value": 1, "controlIndex": 4,
                "states": [
                  { "name": "off", "bindings": [
                      { "type": "amp", "level": "group", "targetId": "grp_b",
                        "parameter": "ENABLED", "translationValue": false } ] },
                  { "name": "on", "bindings": [
                      { "type": "amp", "level": "group", "targetId": "grp_b",
                        "parameter": "ENABLED", "translationValue": true } ] }
                ]
              }
            ],
            "images": [
              { "id": "img_led", "rect": { "x": 300, "y": 20, "width": 16, "height": 16 },
                "image": "img:sink_led", "aspectRatioMode": "preserved",
                "controlIndex": 5, "visible": true }
            ],
            "menus": [
              {
                "id": "menu_amp", "rect": { "x": 330, "y": 20, "width": 120, "height": 24 },
                "value": 1, "textColor": "FFE8E9EA", "backgroundColor": "40000000",
                "hAlign": "center", "controlIndex": 6, "visible": true,
                "options": [
                  { "name": "Clean", "seqIndex": 0, "bindings": [
                      { "type": "effect", "level": "instrument", "targetId": "fx_shape",
                        "parameter": "FX_DRIVE", "effectIndex": 4, "translationValue": "1.0" } ] },
                  { "name": "Crunch", "seqIndex": 1, "bindings": [
                      { "type": "effect", "level": "instrument", "targetId": "fx_shape",
                        "parameter": "FX_DRIVE", "effectIndex": 4, "translationValue": "8.0" } ] }
                ]
              }
            ]
          }
        ],
        "keyboard": {
          "colors": [
            { "loNote": 36, "hiNote": 60, "color": "FF80CBC4" },
            { "loNote": 24, "hiNote": 25, "color": "none" }
          ],
          "labels": [
            { "loNote": 24, "hiNote": 24, "text": "↑" },
            { "loNote": 36, "hiNote": 47, "text": "Major" }
          ]
        },
        "buttonLinks": [
          { "fromButton": 0, "fromState": 1, "toButton": 1, "toState": 1 },
          { "fromButton": -1, "fromState": 0, "toButton": -1, "toState": 0,
            "fromId": "btn_dt", "toId": "btn_stereo" }
        ]
      }
    }
  ]
}
